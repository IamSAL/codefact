{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "codefacts",
  "version": "0.1.0",
  "identifier": "dev.codefacts.desktop",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "codefacts",
        "label": "main",
        "width": 760,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
